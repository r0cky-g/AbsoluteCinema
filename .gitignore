# =============================================================================
# Absolute Cinema — root .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Maven build output
# -----------------------------------------------------------------------------
target/
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# -----------------------------------------------------------------------------
# Vaadin / frontend generated files
# These are regenerated on every build and should never be committed
# -----------------------------------------------------------------------------
**/src/main/frontend/generated/
**/src/main/frontend/node_modules/
**/src/main/frontend/.pnp/
**/src/main/frontend/.pnp.js

# Vaadin dev-bundle (produced at runtime, not source)
**/target/dev-bundle/
**/target/classes/META-INF/VAADIN/

# Vaadin dev server settings (machine-specific paths inside)
**/target/vaadin-dev-server-settings.json

# npm / node
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.npmrc

# -----------------------------------------------------------------------------
# IDE — IntelliJ IDEA
# -----------------------------------------------------------------------------
.idea/
*.iws
*.iml
*.ipr
out/

# -----------------------------------------------------------------------------
# IDE — Eclipse / STS
# -----------------------------------------------------------------------------
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/
bin/

# -----------------------------------------------------------------------------
# IDE — VS Code
# -----------------------------------------------------------------------------
.vscode/

# -----------------------------------------------------------------------------
# IDE — NetBeans
# -----------------------------------------------------------------------------
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Environment / secrets — never commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
application-local.properties
application-secret.properties
*.pem
*.key
*.p12

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
spring.log

# -----------------------------------------------------------------------------
# Maven wrapper jar (binary, fetched automatically)
# -----------------------------------------------------------------------------
.mvn/wrapper/maven-wrapper.jar